# -----------------------------------------------------------------------------
# Copy to `.env.local` for local Next.js (`npm run dev`).
# -----------------------------------------------------------------------------
# Supabase (required for auth, data, realtime, storage outside mock fallbacks)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_jwt_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_jwt_here

# Mapbox (maps and route optimisation)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Cron / privileged API Bearer (matches `Authorization: Bearer <CRON_SECRET>`)
# Vercel: set `CRON_SECRET` in Project Settings → when Cron Jobs invoke your
# endpoints, they send `Authorization: Bearer <CRON_SECRET>` automatically.
# Local: curl -H "Authorization: Bearer $CRON_SECRET" http://localhost:3000/api/anomaly-check
CRON_SECRET=replace_with_long_random_string

# IoT demo simulation (no hardware) — updates bins via /api/iot-simulate
# Set to true for demos; Vercel cron calls this route every 2 minutes when enabled.
IOT_SIMULATION_ENABLED=true
# Optional fixed seed for reproducible fill-level walks (e.g. 42)
IOT_SIMULATION_SEED=42
# Local loop: npm run simulate:iot (loads .env.local automatically; requires npm run dev)

# Optional dedicated IoT webhook secret (falls back to CRON_SECRET)
IOT_WEBHOOK_SECRET=

# Driver fleet demo simulation — moves drivers on active routes (fleet map + anomaly-check)
DRIVER_SIMULATION_ENABLED=true
# Set true occasionally to demo anomaly alerts (far + stale GPS)
DRIVER_SIMULATION_ANOMALY=false
DRIVER_SIMULATION_STEP_METERS=80
# Tick interval for local loop (ms); 3000 recommended with client 60fps interpolation
DRIVER_SIMULATE_INTERVAL_MS=3000
# Client animation duration between GPS pings (ms); defaults to ping interval
NEXT_PUBLIC_DRIVER_ANIMATION_MS=3000
# 3D truck GLB on live map (default: /magirus_d_serie_dump_truck.glb in public/)
NEXT_PUBLIC_TRUCK_GLB_URL=/magirus_d_serie_dump_truck.glb
# Size on map — increase if truck too small (try 2–5)
NEXT_PUBLIC_TRUCK_MODEL_SCALE=2.2
# Local loop: npm run simulate:driver

# Resend (optional — email notifications)
RESEND_API_KEY=

# Twilio (optional — SMS notifications)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
